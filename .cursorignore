# Cursor codebase index — Frappe bench (/apps)
# Strategy: exclude file types & build/vendor paths inside every app — NOT whole app folders.
# Analysis (2026-06): ~93,300 files total → ~9,700 indexable after rules below.
# Keeps: .py, DocType .json, hooks, custom public/js, www/, fixtures, patches.
# public/shared/ is fully indexed (website theme assets).

# ── Dependencies (inside apps, not app roots) ─────────────────────
**/node_modules/
**/.git/
**/.venv/
**/venv/
**/env/

# ── Python bytecode & caches ─────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.tox/
**/.hypothesis/
*.egg-info/
**/*.egg-info/

# ── Build & compiled frontend output ─────────────────────────────
**/dist/
**/build/
**/public/dist/
*.comp.js
*.tsbuildinfo

# ── Package lock files (large, not source logic) ─────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
poetry.lock
Pipfile.lock

# ── Minified & source maps (vendor bundles) ──────────────────────
*.min.js
*.min.css
*.map

# ── Binary & compiled extensions ─────────────────────────────────
*.so
*.dll
*.dylib
*.wasm
*.exe

# ── Images & media (not useful for code search) ──────────────────
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.bmp
*.mp4
*.avi
*.mov
*.mp3
*.wav
*.zip
*.tar
*.tar.gz
*.gz
*.7z
*.pdf

# ── Fonts ────────────────────────────────────────────────────────
*.woff
*.woff2
*.ttf
*.eot
*.otf

# ── Translation binaries (compiled; .po kept) ────────────────────
*.mo

# ── Logs, secrets, local env ─────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.*
!.env.example

# ── Test runners & coverage (E2E/unit artifacts) ─────────────────
**/cypress/
**/htmlcov/
**/.nyc_output/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover

# ── IDE & editor ─────────────────────────────────────────────────
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Generated docs (paths inside apps) ───────────────────────────
**/public/images/
**/docs/_build/
**/docs/current/

# ── Always index public/shared (website theme — override rules above) ─
!**/public/shared/
!**/public/shared/**
!**/public/shared/**/*.js
!**/public/shared/**/*.css
